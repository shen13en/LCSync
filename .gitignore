# .gitignore for LCSync

# Build outputs
bin/
obj/
publish/
dist/
release/

# NuGet packages
packages/
*.nupkg

# IDE files
.vs/
*.suo
*.user
.DS_Store
*.swp

# Logs
*.log
*.txt

# Temporary files
*.tmp
*.bak

# OS files
Thumbs.db
desktop.ini

# Icons generated by script
app.ico
app.png

# Script outputs
scripts/*.ps1
